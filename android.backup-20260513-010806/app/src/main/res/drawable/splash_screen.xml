<?xml version="1.0" encoding="utf-8"?>
<!--
    Used as windowBackground so cold-start (launcher / link redirect) shows
    a black canvas with the Accord logo instead of the system's white flash.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#080808" />
        </shape>
    </item>
    <item
        android:width="120dp"
        android:height="120dp"
        android:gravity="center">
        <bitmap android:src="@drawable/accord_logo" />
    </item>
</layer-list>
