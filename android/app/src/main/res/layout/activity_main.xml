<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080808"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="28dp"
        android:paddingVertical="44dp">

        <!-- ─── Signed-out: hero + Continue with Google ─────────────── -->
        <LinearLayout
            android:id="@+id/signedOutView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:visibility="visible">

            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/accord_wordmark"
                android:contentDescription="@string/app_name"
                android:layout_marginBottom="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACCORD"
                android:textSize="11sp"
                android:textColor="#80F0F0F0"
                android:letterSpacing="0.5"
                android:layout_marginBottom="32dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sign_in_tagline"
                android:textSize="14sp"
                android:textColor="#A6F0F0F0"
                android:textAlignment="center"
                android:lineSpacingMultiplier="1.6"
                android:layout_marginBottom="36dp" />

            <Button
                android:id="@+id/continueWithGoogleBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/continue_with_google"
                android:textColor="#080808"
                android:textAllCaps="false"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/btn_primary"
                android:drawableStart="@drawable/ic_google_g"
                android:drawablePadding="10dp"
                android:paddingHorizontal="20dp"
                android:paddingVertical="14dp"
                android:stateListAnimator="@null"
                android:elevation="0dp" />

        </LinearLayout>

        <!-- ─── Signed-in: profile + dashboard + history ─────────────── -->
        <LinearLayout
            android:id="@+id/signedInView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Top row: wordmark + settings cog -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACCORD"
                    android:textSize="12sp"
                    android:textColor="#A6F0F0F0"
                    android:letterSpacing="0.5"
                    android:layout_centerVertical="true"
                    android:layout_alignParentStart="true" />

                <ImageButton
                    android:id="@+id/settingsBtn"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_settings"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/settings"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true" />
            </RelativeLayout>

            <!-- Profile chip -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/profile_chip_bg"
                android:padding="12dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/avatarView"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:gravity="center"
                    android:textColor="#F0F0F0"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:background="@drawable/avatar_circle"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/nameView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#F0F0F0"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:singleLine="true"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/emailView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#80F0F0F0"
                        android:textSize="12sp"
                        android:singleLine="true"
                        android:ellipsize="end" />
                </LinearLayout>
            </LinearLayout>

            <!-- Open dashboard -->
            <Button
                android:id="@+id/dashboardBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/open_dashboard"
                android:textColor="#080808"
                android:textAllCaps="false"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/btn_primary"
                android:paddingVertical="14dp"
                android:stateListAnimator="@null"
                android:elevation="0dp"
                android:layout_marginBottom="14dp" />

            <Button
                android:id="@+id/signOutBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sign_out"
                android:textColor="#FF6B6B"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:background="@drawable/btn_danger_outline"
                android:paddingVertical="12dp"
                android:stateListAnimator="@null"
                android:elevation="0dp"
                android:layout_marginBottom="32dp" />

            <!-- Setup card (forms.gle default app) -->
            <LinearLayout
                android:id="@+id/setupCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/setup_card_bg"
                android:padding="20dp"
                android:layout_marginBottom="32dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setup_required"
                    android:textColor="#F0F0F0"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/setup_blurb"
                    android:textColor="#80F0F0F0"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.55"
                    android:layout_marginBottom="14dp" />

                <Button
                    android:id="@+id/enableButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/open_settings"
                    android:textColor="#080808"
                    android:textAllCaps="false"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/btn_primary"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="9dp"
                    android:stateListAnimator="@null"
                    android:elevation="0dp" />
            </LinearLayout>

            <!-- History header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/history_header"
                android:textColor="#F0F0F0"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:layout_marginBottom="14dp" />

            <TextView
                android:id="@+id/historyEmptyView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/history_empty"
                android:textColor="#80F0F0F0"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.55"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/historyList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
