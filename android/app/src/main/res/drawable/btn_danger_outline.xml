<?xml version="1.0" encoding="utf-8"?>
<!-- Red-outline button — matches the web app's `.btn-danger` aesthetic. -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#33DC3232">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1ADC3232" />
            <stroke android:width="1dp" android:color="#33DC3232" />
            <corners android:radius="10dp" />
        </shape>
    </item>
</ripple>
